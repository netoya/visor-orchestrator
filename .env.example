# Ruta absoluta al archivo SQLite del autonomous-orchestrator que el visor lee en modo readonly.
# Obligatoria si la base no esta en el default. Default: /home/angel/projects/autonomous-orchestrator/state/orchestrator.db
ORCHESTRATOR_DB_PATH=/home/angel/projects/autonomous-orchestrator/state/orchestrator.db
# Puerto en el que escucha el backend Hono y sirve los estaticos del frontend.
# Opcional. Default: 5176
PORT=5176
